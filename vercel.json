{
    "outputDirectory":  "frontend/dist",
    "buildCommand":  "npm install --prefix frontend \u0026\u0026 npm run build --prefix frontend",
    "env":  {
                "VITE_API_BASE":  "http://localhost:3001"
            },
    "version":  2,
    "rewrites":  [
                     {
                         "destination":  "http://localhost:3001/",
                         "source":  "/api/(.*)"
                     }
                 ]
}